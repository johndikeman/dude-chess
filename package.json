{
  "name": "dude-chess",
  "version": "0.1.0",
  "description": "A self-improving AI agent for chess analysis",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "dude-chess": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "test": "export NODE_ENV=test; node src/scheduler.test.js && node src/sessions.test.js && node src/index.test.js && node src/agent.acceptance.test.js && node test_audit.js && node test/scheduler-quota-test.js",
    "test:scheduler": "node src/scheduler.test.js",
    "test:index": "node src/index.test.js",
    "test:sessions": "node src/sessions.test.js",
    "test:acceptance": "node src/agent.acceptance.test.js",
    "test:audit": "node test_audit.js",
    "test:quota": "node test/scheduler-quota-test.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./scheduler": "./src/scheduler.js"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "chalk": "^5.6.2",
    "discord.js": "^14.26.2",
    "dotenv": "^17.4.1",
    "strip-ansi": "^7.2.0",
    "undici": "^8.0.2"
  }
}
